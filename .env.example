# ─── Base de Datos ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/biotrack_db"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# Dominio del tenant (sin https://)
AUTH0_DOMAIN="tu-tenant.auth0.com"
# Audience = API Identifier configurado en Auth0 Dashboard → APIs
AUTH0_AUDIENCE="https://biotrack-api"
# Machine-to-Machine app con permisos read:users, create:users, update:users, block_users
AUTH0_MGMT_CLIENT_ID="tu_mgmt_client_id"
AUTH0_MGMT_CLIENT_SECRET="tu_mgmt_client_secret"

# ─── Cifrado AES-256-GCM (para PII: contacto_denunciante) ─────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="clave_hex_de_64_caracteres_generada_con_openssl_rand_hex_32"

# ─── Email Transaccional ──────────────────────────────────────────────────────
EMAIL_PROVIDER="smtp"
EMAIL_HOST="smtp.mailtrap.io"
EMAIL_PORT=2525
EMAIL_USER="tu_usuario_mailtrap"
EMAIL_PASS="tu_contrasena_mailtrap"
EMAIL_FROM="noreply@biotrack.gob.do"
EMAIL_FROM_NAME="BIOTRACK"

# ─── Almacenamiento de Objetos ────────────────────────────────────────────────
STORAGE_PROVIDER="local"
STORAGE_LOCAL_PATH="./uploads"
STORAGE_MAX_FILE_SIZE_MB=5
STORAGE_MAX_TOTAL_SIZE_MB=10

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Frontend URL (para CORS y links en emails) ───────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ─── Logs ─────────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
