*
!*/
# ─── Directorios completamente ignorados ─────────────────────────────────────
node_modules/
dist/
uploads/
coverage/
reports/

# ─── Archivos raíz permitidos ─────────────────────────────────────────────────
!.gitignore
!.env.example
!package.json
!package-lock.json
!tsconfig.json
!README.md
!LICENSE

# ─── Código fuente TypeScript ────────────────────────────────────────────────
!src/
!src/**

# ─── Prisma (esquema, seed, migraciones) ─────────────────────────────────────
!prisma/
!prisma/**

# ─── Scripts ─────────────────────────────────────────────────────────────────
!scripts/
!scripts/**

# ─── Tests ───────────────────────────────────────────────────────────────────
!tests/
!tests/**

# ─── GitHub Actions ──────────────────────────────────────────────────────────
!.github/
!.github/**
